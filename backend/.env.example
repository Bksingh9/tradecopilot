# --- TradeCopilot Agent dev env ---
APP_ENV=dev
APP_NAME=TradeCopilot
LOG_LEVEL=INFO

# DB: SQLite for dev, Postgres for prod
DATABASE_URL=sqlite:///./tradecopilot.db
# DATABASE_URL=postgresql+psycopg2://tc:tc@localhost:5432/tradecopilot

# Auth secrets (CHANGE THESE)
JWT_SECRET=replace-me-with-a-long-random-string
JWT_ALG=HS256
JWT_TTL_MIN=60
# Fernet key for at-rest encryption of broker tokens. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_FERNET_KEY=replace-me-with-base64-fernet-key

# Indian Stock Market API (0xramm)
NSE_API_BASE=https://nse-api-khaki.vercel.app

# Alpaca (US equities)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true
ALPACA_DATA_BASE=https://data.alpaca.markets
ALPACA_TRADE_BASE=https://paper-api.alpaca.markets

# Zerodha
ZERODHA_API_KEY=
ZERODHA_API_SECRET=

# Upstox
UPSTOX_CLIENT_ID=
UPSTOX_CLIENT_SECRET=
UPSTOX_REDIRECT_URI=http://localhost:8000/api/auth/upstox/callback

# Billing (stub)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AI coach
# AI_COACH_BACKEND=fake → returns deterministic placeholder text (no LLM call).
# AI_COACH_BACKEND=external → backend pushes rendered prompts to Redis;
#   the worker (app.workers.ai_worker) calls AI_SERVICE_URL and posts the
#   response to /api/ai/callback using AI_WORKER_ADMIN_TOKEN.
AI_COACH_BACKEND=fake
AI_SERVICE_URL=
AI_SERVICE_API_KEY=
AI_WORKER_ADMIN_TOKEN=
AI_EXTERNAL_WEBHOOK=

# Redis / queues
REDIS_URL=redis://localhost:6379/0
AI_QUEUE_NAME=tradecopilot:ai_jobs
AI_WORKER_HEARTBEAT_KEY=tradecopilot:ai_worker:heartbeat
AI_WORKER_HEARTBEAT_TTL_S=60

# Risk hard caps — CANNOT be loosened by AI suggestions or user edits.
KILL_SWITCH_HARD_DAILY_LOSS_PCT=5.0
KILL_SWITCH_HARD_MAX_OPEN_POSITIONS=20

# Partner API
PARTNER_API_SECRET=replace-me-with-a-long-random-string

# Caches
DATA_CACHE_DIR=./data_cache
BACKTEST_WORKDIR=./backtest_runs

# Prediction service (joblib model registry)
MODELS_DIR=./models

# Vector memory backend
# memory   → in-process numpy + cosine (default; great for dev)
# pgvector → stub; wire to a Postgres pgvector table in prod (see app.vector_memory.db.PgVectorBackend docstring)
VECTOR_BACKEND=memory
